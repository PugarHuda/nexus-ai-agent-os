{
  "name": "Sentiment Analysis",
  "version": "1.0.0",
  "description": "Analyzes text sentiment (positive/negative/neutral) with confidence score. Supports crypto/DeFi context.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "text": { "type": "string", "description": "Text to analyze" },
      "context": { "type": "string", "enum": ["general", "crypto", "defi", "news"], "default": "general" }
    },
    "required": ["text"]
  },
  "outputSchema": {
    "type": "object",
    "properties": {
      "sentiment": { "type": "string", "enum": ["positive", "negative", "neutral"] },
      "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
      "reasoning": { "type": "string" }
    }
  },
  "pricing": {
    "perUse": "0.001",
    "subscription": "0.1",
    "currency": "0G"
  },
  "model": "deepseek-chat-v3-0324",
  "category": "analysis"
}
